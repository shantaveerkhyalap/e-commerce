<%- include('./partials/header') %>
    <% if(success.length>0){ %>
        <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
            <span class="inline-block mt-1 mb-1 text-white">
                <%= success %>
            </span>
        </div>
        <% } %>


            <% if (user.orders.length===0) { %>
                <p class="text-center text-gray-500 mt-10">No orders placed yet.</p>
                <% } else { %>
                    <div class="grid grid-cols-3 gap-6 mt-6">
                        <% user.orders.forEach((product)=> { %>
                            <div class="border rounded shadow-sm overflow-hidden">
                                <!-- Product Image -->
                                <div class="w-full h-52 flex items-center justify-center"
                                    style="background-color: <%= product.bgcolor %>">
                                    <img class="h-48 object-contain"
                                        src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
                                </div>

                                <!-- Product Info -->
                                <div class="flex justify-between items-center px-4 py-3 bg-[<%=product.bgcolor %>] "
                                    style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>">
                                    <div>
                                        <h3 class="text-lg font-semibold">
                                            <%= product.name %>
                                        </h3>
                                        <h4 class="text-sm">&#8377;<%= product.price %>
                                        </h4>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>



                        <%- include('./partials/footer') %>