<%- include('./partials/header') %>

<div class="max-w-md mx-auto mt-20 p-6 border border-gray-300 rounded-lg shadow-lg">
  <h2 class="text-2xl font-semibold mb-4 text-center">Create a New Collection</h2>

  <% if(success.length > 0) { %>
    <div class="bg-green-500 text-white px-4 py-2 rounded mb-3">
      <%= success %>
    </div>
  <% } %>
  <% if(error.length > 0) { %>
    <div class="bg-red-500 text-white px-4 py-2 rounded mb-3">
      <%= error %>
    </div>
  <% } %>

  <form action="/users/newCollection" method="POST" class="space-y-4">

    <div>
      <label class="block mb-1 font-medium">Collection Title</label>
      <input type="text" name="title" required
             class="w-full px-3 py-2 border border-gray-400 rounded focus:outline-none focus:ring focus:border-blue-400"
             placeholder="e.g., My Summer Wishlist" />
    </div>

    <div class="text-center">
      <button type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded">
        Create Collection
      </button>
    </div>
  </form>
</div>

<%- include('./partials/footer') %>
